## 📦 Key Dependencies

```json
{
  "dependencies": {
    "next": "^14.2",
    "react": "^18.3",
    "react-dom": "^18.3",
    "axios": "^1.7",
    "@react-google-maps/api": "^2.19",
    "chart.js": "^4.4",
    "react-chartjs-2": "^5.2",
    "react-quill": "^2.0",
    "react-hot-toast": "^2.4",
    "react-icons": "^5.0",
