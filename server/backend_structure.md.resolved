## 📁 src/routes/

```
src/routes/
├── 📄 index.js                        # Master router ─ mounts all sub-routes

│── ── Public Routes ───────────────────
├── 📄 auth.routes.js                  # /api/auth/*
├── 📄 property.routes.js              # /api/properties/*  (public endpoints)
├── 📄 blog.routes.js                  # /api/blog/*
├── 📄 content.routes.js               # /api/testimonials, /api/faqs, /api/contact

│── ── Authenticated User Routes ───────
├── 📄 user.routes.js                  # /api/users/*
├── 📄 favorite.routes.js              # /api/favorites/*, /api/comparisons/*
├── 📄 review.routes.js                # /api/reviews/*
├── 📄 inquiry.routes.js               # /api/inquiries/*
├── 📄 propertyRequest.routes.js       # /api/property-requests/*
├── 📄 notification.routes.js          # /api/notifications/*
├── 📄 search.routes.js                # /api/saved-searches/*

│── ── Admin Routes ────────────────────
├── 📄 admin.user.routes.js            # /api/admin/users/*
├── 📄 admin.property.routes.js        # /api/admin/properties/* (full CRUD)
├── 📄 admin.lead.routes.js            # /api/admin/leads/*, /api/admin/inquiries/*
├── 📄 admin.request.routes.js         # /api/admin/property-requests/* (ROI review)
├── 📄 admin.blog.routes.js            # /api/admin/blog/*
├── 📄 admin.content.routes.js         # /api/admin/faqs, testimonials, contact msgs
├── 📄 admin.notification.routes.js    # /api/admin/notifications/*
├── 📄 admin.analytics.routes.js       # /api/admin/dashboard/*, analytics, reports
└── 📄 admin.audit.routes.js           # /api/admin/audit-logs/*, security/*
```

