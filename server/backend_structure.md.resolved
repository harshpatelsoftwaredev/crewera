├── 📄 legal.validator.js              # RERA, legal compliance schemas
├── 📄 buildingSpec.validator.js       # Building specs, utilities schemas
├── 📄 review.validator.js             # Review submit (ratings 1-5, text)
├── 📄 lead.validator.js               # Lead create, status update, assign schemas
├── 📄 inquiry.validator.js            # Inquiry submit, reply schemas
├── 📄 propertyRequest.validator.js    # Request submit (ROI required), completion form
├── 📄 blog.validator.js               # Post create/update, comment, category schemas
├── 📄 content.validator.js            # Testimonial, FAQ, contact message schemas
├── 📄 notification.validator.js       # Send notification, template schemas
└── 📄 search.validator.js             # Saved search criteria, params
```

