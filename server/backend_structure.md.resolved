## 📁 src/models/

```
src/models/
├── 📄 index.js                        # Sequelize init + model associations

│── ── MODULE 1: Users ─────────────────
├── 📄 User.js                         # Auth: email, password, role, tokens
├── 📄 UserProfile.js                  # Personal info, bio, address
├── 📄 UserPreference.js               # Notifications, privacy, display prefs

│── ── MODULE 2: Property Core ─────────
├── 📄 Property.js                     # Core identity: name, type, status, slug
├── 📄 PropertyDetail.js               # Builder, description, units, towers
├── 📄 PropertyConstruction.js         # Stage, %, dates, inspection

│── ── MODULE 3–6: Property Extended ───
├── 📄 PropertyLocation.js             # Address, city, lat/lng, landmarks
├── 📄 PropertyLegal.js                # RERA, compliance, certificates
├── 📄 PropertyBuildingSpec.js          # Storeys, lifts, parking, structure
├── 📄 PropertyUtility.js              # Electric, gas, water, maintenance

│── ── MODULE 7: Amenities ─────────────
├── 📄 AmenityMaster.js                # Amenity catalog
├── 📄 PropertyAmenity.js              # Property ↔ Amenity mapping

│── ── MODULE 8: Pricing & Units ───────
├── 📄 PropertyPricing.js              # BHK types, price, ROI, revenue
├── 📄 UnitSpecification.js            # Dimensions, facing, features

│── ── MODULE 9–10: Contacts & Media ───
├── 📄 PropertyContact.js              # Sales head, developer contacts
├── 📄 MediaCategory.js                # Photo, Video, Floorplan categories
├── 📄 PropertyMedia.js                # Uploaded files, thumbnails

│── ── MODULE 11–12: Analytics ─────────
├── 📄 PropertyAnalytics.js            # Aggregated view/inquiry/share counts
├── 📄 PropertyViewLog.js              # Individual page view records
├── 📄 PropertyMilestone.js            # Construction progress tracking

│── ── MODULE 13: Reviews ──────────────
├── 📄 PropertyReview.js               # Ratings, review text, moderation

│── ── MODULE 14: Leads & Inquiries ────
├── 📄 PropertyLead.js                 # Sales pipeline, scoring, follow-up
├── 📄 Inquiry.js                      # Property/general inquiries

│── ── MODULE 15: Property Requests ────
├── 📄 PropertyRequest.js              # User listing requests (ROI, financials)

│── ── MODULE 16: Favorites ────────────
├── 📄 Favorite.js                     # User ↔ Property favorites
├── 📄 PropertyComparison.js           # Compare lists (JSON property_ids)

│── ── MODULE 17: Blog ─────────────────
├── 📄 BlogCategory.js                 # Category catalog
├── 📄 BlogPost.js                     # Posts, slug, SEO, scheduling
├── 📄 BlogComment.js                  # Threaded comments

│── ── MODULE 18: Testimonials & FAQs ──
├── 📄 Testimonial.js                  # User testimonials
├── 📄 Faq.js                          # FAQ entries with categories

│── ── MODULE 19: Communication ────────
├── 📄 ContactMessage.js               # Contact form submissions
├── 📄 Notification.js                 # In-app notifications
├── 📄 NotificationTemplate.js         # Reusable email/SMS/push templates

│── ── MODULE 20: Audit & Security ─────
├── 📄 AuditLog.js                     # Action audit trail (CRUD, login)
├── 📄 AuditActivity.js                # Behavioral analytics
├── 📄 LoginHistory.js                 # Login/logout session records

│── ── MODULE 21–22: Price & Tags ──────
├── 📄 PropertyPriceHistory.js         # Price change tracking over time
├── 📄 Tag.js                          # Tag catalog
├── 📄 PropertyTag.js                  # Property ↔ Tag mapping
└── 📄 SavedSearch.js                  # User saved searches + alerts
```

